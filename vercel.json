{
  "version": 2,
  "outputDirectory": "public",
  "buildCommand": "",
  "functions": {
    "api/index.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api", "destination": "/api/index.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js?path=$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
